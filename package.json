{
  "name": "svg-to-deck-converter",
  "version": "0.1.0",
  "description": "Render AntV Infographic Gallery templates with custom data and convert to TipTap deck JSON",
  "type": "module",
  "main": "./dist/node/index.cjs",
  "module": "./dist/browser/index.js",
  "types": "./dist/browser/index.d.ts",
  "browser": "./dist/browser/index.js",
  "exports": {
    ".": {
      "types": "./dist/browser/index.d.ts",
      "browser": {
        "import": "./dist/browser/index.js",
        "require": "./dist/browser/index.cjs",
        "default": "./dist/browser/index.js"
      },
      "node": {
        "import": "./dist/node/index.js",
        "require": "./dist/node/index.cjs",
        "default": "./dist/node/index.js"
      },
      "import": "./dist/browser/index.js",
      "require": "./dist/node/index.cjs",
      "default": "./dist/node/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "download:resources": "node scripts/download-gallery-resources.mjs",
    "download:fonts": "node scripts/download-gallery-fonts.mjs",
    "build": "node scripts/clean-dist.mjs && node --max-old-space-size=8192 node_modules/tsup/dist/cli-default.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:dist": "npm run dev --prefix dist-test",
    "lint": "oxlint"
  },
  "keywords": [
    "svg",
    "tiptap",
    "deck",
    "infographic",
    "antv",
    "converter"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.14.1"
  },
  "devDependencies": {
    "@antv/infographic": "^0.2.19",
    "@tiptap/core": "^3.27.1",
    "@tiptap/extension-document": "^3.27.1",
    "@tiptap/extension-paragraph": "^3.27.1",
    "@tiptap/extension-text": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@types/node": "^18.19.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "happy-dom": "17.6.1",
    "oxlint": "~1.16.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.5.0",
    "typescript": "~6.0.2",
    "vite": "^6.4.3",
    "vitest": "^3.2.7"
  },
  "dependencies": {
    "measury": "^0.1.5"
  }
}
