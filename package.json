{
  "name": "svg-to-deck-converter",
  "version": "0.1.0",
  "description": "Render AntV Infographic Gallery templates with custom data and convert to TipTap deck JSON",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.lib.json",
    "lint": "oxlint"
  },
  "keywords": [
    "svg",
    "tiptap",
    "deck",
    "infographic",
    "antv",
    "converter"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.18.0"
  },
  "dependencies": {
    "@antv/infographic": "^0.2.19"
  },
  "devDependencies": {
    "@tiptap/core": "^3.27.1",
    "@tiptap/extension-document": "^3.27.1",
    "@tiptap/extension-paragraph": "^3.27.1",
    "@tiptap/extension-text": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@types/node": "^20.19.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "happy-dom": "^20.10.6",
    "oxlint": "~1.16.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "~6.0.2",
    "vite": "^6.4.3"
  }
}
